# Токен бота из https://discord.com/developers/applications  (Bot -> Reset Token)
DISCORD_TOKEN=

# Бесплатный ключ из https://console.groq.com/keys  (используется и для шуток, и для распознавания речи)
GROQ_API_KEY=

# Если указать ID своего сервера — слэш-команды появятся в нём мгновенно (удобно для тестов).
# Без него команды синхронизируются глобально и появляются в течение ~часа.
DEBUG_GUILD=

# --- Можно не трогать ---
LLM_MODEL=llama-3.3-70b-versatile
STT_MODEL=whisper-large-v3-turbo
STT_LANGUAGE=ru
TTS_VOICE=ru-RU-DmitryNeural
